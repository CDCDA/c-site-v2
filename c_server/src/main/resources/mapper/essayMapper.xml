<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pw.mapper.EssayMapper">
    <resultMap type="com.pw.vo.EssayVO" id="essayMap">
        <id property="id" column="id"/>
        <result property="content" column="content"/>
        <result property="userId" column="user_id"/>
        <collection property="images" javaType="list" ofType="String" select="getImagesByEssayId"
                    column="{essayId = id}">
            <result column="url"/>
        </collection>
    </resultMap>

    <!--按id查询图片集合-->
    <select id="getImagesByEssayId" resultType="String">
        select i.url
        from essay e
                 join image_relation i ON e.id = i.essay_id
        where e.id = #{essayId}
    </select>

    <!--按id查询随笔-->
    <select id="getEssayById" resultMap="essayMap">
        select
        e.id,
        e.content,
        e.user_id,
        e.tags,
        e.create_time
        from essay e
        <where>
            <if test="essayId != null and essayId != ''">
                and e.id = #{essayId}
            </if>
        </where>
    </select>

    <!--随笔分页查询-->
    <select id="page" resultMap="essayMap">
        select
        e.id,
        e.content,
        e.user_id,
        e.tags,
        e.create_time
        from essay e
        <where>
            <if test="param.userId != null and param.userId != ''">
                and e.user_id = #{param.userId}
            </if>
            <if test="param.content != null and param.content != ''">
                and e.content like concat('%', #{param.content}, '%')
            </if>
            <if test="param.startTime != null and param.endTime != null">
                and e.create_time between #{param.startTime} and #{param.endTime}
            </if>
        </where>
        order by create_time desc
    </select>

    <!--随笔统计-->
    <select id="count" resultType="integer">
        select count(*)
        from essay e
        <where>
            <if test="userId != null and userId != ''">
                and e.user_id = #{userId}
            </if>
            <if test="content != null and content != ''">
                and e.content like concat('%', #{content}, '%')
            </if>
            <if test="startTime != null and endTime != null">
                and e.create_time between #{startTime} and #{endTime}
            </if>
        </where>
    </select>

    <!--按月份查询随笔统计 - MySQL版本-->
    <select id="countEssayByDateRange" resultType="com.pw.vo.EssayCountVO">
        SELECT
        DATE_FORMAT(create_time, '%Y年%m月') as create_time,
        count(*) as total
        FROM
        essay
        <where>
            <if test="userId != null and userId != ''">
                and user_id = #{userId}
            </if>
            <if test="startTime != null and endTime != null">
                and create_time between #{startTime} and #{endTime}
            </if>
        </where>
        GROUP BY
        DATE_FORMAT(create_time, '%Y年%m月')
        ORDER BY
        DATE_FORMAT(create_time, '%Y年%m月')
    </select>
</mapper>
